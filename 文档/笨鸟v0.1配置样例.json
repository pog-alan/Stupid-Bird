      "effect": "目标稳定性变为翻倒"
    },
    {
      "event": "泄漏",
      "effect": "液体与目标表面建立覆盖关系"
    },
    {
      "event": "堆放",
      "effect": "目标增加堆积属性并绑定位置"
    },
    {
      "event": "散落",
      "effect": "目标增加散乱属性并绑定位置"
